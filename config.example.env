# 複製此檔為 .env 並填入你的設定

# 通知渠道（可多選）: telegram | email | callmebot | twilio
NOTIFY_CHANNELS=telegram

# Telegram（推薦，免費穩定）
# @BotFather 建立 bot → 向 bot 發訊息 → getUpdates 取得 chat id
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Email 備用（Gmail 用應用程式密碼）
EMAIL_SMTP_HOST=smtp.gmail.com
EMAIL_SMTP_PORT=587
EMAIL_SMTP_USER=
EMAIL_SMTP_PASSWORD=
EMAIL_TO=

# CallMeBot WhatsApp（免費但不穩定）
WHATSAPP_PHONE=
CALLMEBOT_APIKEY=

# Twilio WhatsApp（付費）
WHATSAPP_PROVIDER=twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
WHATSAPP_TO=whatsapp:+85291234567

INITIAL_RUN_NOTIFY=false
EDB_CIRCULAR_LOOKBACK_DAYS=90

# GitHub Actions Secrets: NOTIFY_CHANNELS, TELEGRAM_BOT_TOKEN, TELEGRAM_CHAT_ID, ...
